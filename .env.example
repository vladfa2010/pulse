# Server
PORT=3001
NODE_ENV=development

# Database: SQLite (zero-config) or PostgreSQL
USE_SQLITE=true
SQLITE_FILE=./pulse.db

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pulse
DB_USER=pulse_user
DB_PASSWORD=your_password

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Telegram Bot (@Insidepulse_bot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Application URLs
FRONTEND_URL=https://pulse.inside-trade.ru
BACKEND_URL=https://pulse-api-bsov.onrender.com

# YooKassa (payments)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
# YOOKASSA_OAUTH_TOKEN=your_oauth_token  # optional: required only for automatic webhook registration

# Email Provider: 'resend' | 'yandex' | 'none'
# Resend: https://resend.com — 3,000 emails/month free (~100/day)
#         Without a verified domain use *@resend.dev (e.g. noreply@resend.dev)
# Yandex: https://yandex.ru — SMTP, need app password, 500/day
EMAIL_PROVIDER=none
EMAIL_FROM=noreply@pulse.app

# Resend API (if EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_xxxxxxxx

# Yandex SMTP (if EMAIL_PROVIDER=yandex)
YANDEX_USER=your_email@ya.ru
YANDEX_PASS=your_app_password

# Translation
TRANSLATION_API_KEY=your_translation_api_key

# RSS
RSS_FETCH_INTERVAL=15

# Firebase Cloud Messaging (push notifications)
# Base64-encoded service-account JSON from Firebase Console → Project settings → Service accounts
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@pulse.app

# Admin
ADMIN_EMAILS=admin@pulse.app
