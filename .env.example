# Server
PORT=3001
NODE_ENV=development

# Database: SQLite (zero-config) or PostgreSQL
USE_SQLITE=true
SQLITE_FILE=./pulse.db

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pulse
DB_USER=pulse_user
DB_PASSWORD=your_password

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Telegram Bot (@pulse_invest_bot)
TELEGRAM_BOT_TOKEN=8226463754:AAHmgNwdTsiMZkbSNwlJjmSRlVZifZ6HeZo

# YooKassa (payments)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_key
EMAIL_FROM=noreply@pulse.app

# Translation
TRANSLATION_API_KEY=your_translation_api_key

# RSS
RSS_FETCH_INTERVAL=15

# Admin
ADMIN_EMAILS=admin@pulse.app
